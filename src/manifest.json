{
  "manifest_version": 3,
  "name": "Video Grabber",
  "version": "0.1.0",
  "description": "Detect MP4/WebM and HLS streams playing in any tab and download them at the highest available quality.",
  "minimum_chrome_version": "109",
  "key": "",
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Video Grabber"
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content-script.ts"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "permissions": [
    "webRequest",
    "downloads",
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "offscreen",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "nativeMessaging"
  ],
  "host_permissions": ["<all_urls>"],
  "web_accessible_resources": [
    {
      "resources": ["src/offscreen/offscreen.html", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
