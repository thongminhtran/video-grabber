{
  "manifest_version": 3,
  "name": "Video Grabber",
  "version": "0.1.0",
  "description": "Detect MP4/WebM and HLS streams playing in any tab and download them at the highest available quality.",
  "minimum_chrome_version": "109",
  "key": "",
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Video Grabber"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content-script.ts-BFO9XRPq.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "permissions": [
    "webRequest",
    "downloads",
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "offscreen",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "nativeMessaging"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "src/offscreen/offscreen.html",
        "assets/*",
        "assets/content-script.ts-BFO9XRPq.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
